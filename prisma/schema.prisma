generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  name          String?
  avatarUrl     String?
  role          UserRole  @default(VISITOR)
  preferredLang String    @default("pt-BR")
  accessibilityPrefs Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  conversations Conversation[]
  achievements  UserAchievement[]
  favorites     Favorite[]
  visits        ArtworkVisit[]
  quizAttempts  QuizAttempt[]

  @@index([email])
}

enum UserRole {
  VISITOR
  MEMBER
  ADMIN
}

model Artist {
  id          String   @id @default(cuid())
  name        String
  nationality String?
  birthYear   Int?
  deathYear   Int?
  bio         String?  @db.Text
  photoUrl    String?
  movements   String[]
  slug        String   @unique
  createdAt   DateTime @default(now())

  artworks    Artwork[]
}

model Artwork {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  artistId        String
  year            Int?
  medium          String?
  dimensions      String?
  location        String?
  locationLat     Float?
  locationLng     Float?
  imageUrl        String
  thumbnailUrl    String?
  description     String?  @db.Text
  historicalCtx   String?  @db.Text
  politicalCtx    String?  @db.Text
  artisticCtx     String?  @db.Text
  hiddenDetails   Json?
  symbolism       Json?
  theories        Json?
  movements       String[]
  tags            String[]
  theme           Json?
  aiSystemPrompt  String?  @db.Text
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  artist          Artist   @relation(fields: [artistId], references: [id])
  conversations   Conversation[]
  favorites       Favorite[]
  visits          ArtworkVisit[]
  quizzes         Quiz[]
  timelineEvents  TimelineEvent[]
  relatedFrom     ArtworkRelation[] @relation("FromArtwork")
  relatedTo       ArtworkRelation[] @relation("ToArtwork")

  @@index([slug])
  @@index([artistId])
}

model ArtworkRelation {
  id           String  @id @default(cuid())
  fromId       String
  toId         String
  relationType String

  from         Artwork @relation("FromArtwork", fields: [fromId], references: [id])
  to           Artwork @relation("ToArtwork", fields: [toId], references: [id])

  @@unique([fromId, toId])
}

model TimelineEvent {
  id          String   @id @default(cuid())
  artworkId   String
  year        Int
  title       String
  description String?  @db.Text
  category    TimelineCategory
  sourceUrl   String?
  imageUrl    String?
  createdAt   DateTime @default(now())

  artwork     Artwork  @relation(fields: [artworkId], references: [id])

  @@index([artworkId])
}

enum TimelineCategory {
  ARTIST_LIFE
  HISTORICAL_EVENT
  ARTWORK_CREATION
  ARTISTIC_MOVEMENT
  WORLD_EVENT
}

model Conversation {
  id          String   @id @default(cuid())
  userId      String?
  artworkId   String
  sessionId   String   @unique
  language    String   @default("pt-BR")
  userLevel   UserLevel @default(ADULT)
  startedAt   DateTime @default(now())
  endedAt     DateTime?
  duration    Int?
  messageCount Int     @default(0)

  user        User?    @relation(fields: [userId], references: [id])
  artwork     Artwork  @relation(fields: [artworkId], references: [id])
  messages    Message[]

  @@index([userId])
  @@index([artworkId])
  @@index([sessionId])
}

enum UserLevel {
  CHILD
  TEEN
  ADULT
  EXPERT
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.Text
  audioUrl       String?
  timestamp      DateTime    @default(now())
  metadata       Json?

  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

model Achievement {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String
  icon        String
  category    AchievementCategory
  points      Int      @default(10)
  criteria    Json
  createdAt   DateTime @default(now())

  userAchievements UserAchievement[]
}

enum AchievementCategory {
  EXPLORATION
  KNOWLEDGE
  ACCESSIBILITY
  SOCIAL
  STREAK
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())
  metadata      Json?

  user          User        @relation(fields: [userId], references: [id])
  achievement   Achievement @relation(fields: [achievementId], references: [id])

  @@unique([userId, achievementId])
}

model Quiz {
  id          String   @id @default(cuid())
  artworkId   String
  title       String
  difficulty  QuizDifficulty @default(MEDIUM)
  questions   Json
  createdAt   DateTime @default(now())

  artwork     Artwork  @relation(fields: [artworkId], references: [id])
  attempts    QuizAttempt[]

  @@index([artworkId])
}

enum QuizDifficulty {
  EASY
  MEDIUM
  HARD
  EXPERT
}

model QuizAttempt {
  id          String   @id @default(cuid())
  quizId      String
  userId      String
  score       Int
  answers     Json
  completedAt DateTime @default(now())

  quiz        Quiz @relation(fields: [quizId], references: [id])
  user        User @relation(fields: [userId], references: [id])

  @@index([quizId])
  @@index([userId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  artworkId String
  createdAt DateTime @default(now())

  user      User    @relation(fields: [userId], references: [id])
  artwork   Artwork @relation(fields: [artworkId], references: [id])

  @@unique([userId, artworkId])
}

model ArtworkVisit {
  id          String   @id @default(cuid())
  userId      String
  artworkId   String
  visitedAt   DateTime @default(now())
  duration    Int?
  completed   Boolean  @default(false)

  user        User    @relation(fields: [userId], references: [id])
  artwork     Artwork @relation(fields: [artworkId], references: [id])

  @@index([userId])
  @@index([artworkId])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  resource  String
  metadata  Json?
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
